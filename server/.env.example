PORT=5800
NODE_ENV=development
AUTO_MIGRATE_ON_START=true
CLIENT_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=jmo_finance
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=replace-with-very-long-random-secret-at-least-32-char
JWT_EXPIRES_IN=12h

BYPASS_CAPTCHA=true
TURNSTILE_SECRET_KEY=

MAX_FAILED_LOGIN=5
LOCKOUT_MINUTES=15
RESET_TOKEN_MINUTES=30
AUTH_RATE_LIMIT_MAX=10
RESET_RATE_LIMIT_MAX=5

SECRET_PROVIDER=env
NOTIFICATION_EMAIL_FROM=noreply@jakartamax.local
